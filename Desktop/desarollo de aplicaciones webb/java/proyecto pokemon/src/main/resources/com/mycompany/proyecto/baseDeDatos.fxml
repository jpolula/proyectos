   <children>
      <Button fx:id="abrir" layoutX="385.0" layoutY="237.0" mnemonicParsing="false" onAction="#aceptar" style="-fx-background-color: black; -fx-background-radius: 15;" text="ACEPTAR" textFill="WHITE" />
      <Button fx:id="btnCerrar" layoutX="456.0" layoutY="237.0" mnemonicParsing="false" onAction="#cerrar" style="-fx-background-color: black; -fx-background-radius: 15;" text="SALIR" textFill="WHITE" />
      <Label alignment="TOP_LEFT" layoutX="141.0" layoutY="57.0" style="-fx-background-color: black;" text="CONEXIÓN A LA BASE DE DATOS" textFill="WHITE">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Button fx:id="btnTest" layoutX="338.0" layoutY="237.0" mnemonicParsing="false" onAction="#testConexion" style="-fx-background-color: black; -fx-background-radius: 15;" text="TEST" textFill="WHITE" />
      <TextField fx:id="btnDriver" layoutX="35.0" layoutY="118.0" promptText="DRIVER" style="-fx-text-fill: white; -fx-background-color: black;" />
      <TextField fx:id="btnIp" layoutX="35.0" layoutY="155.0" promptText="IP" style="-fx-background-color: black; -fx-text-fill: white;" />
      <TextField fx:id="btnBaseDeDatos" layoutX="35.0" layoutY="197.0" promptText="BASE DE DATOS" style="-fx-background-color: black; -fx-text-fill: white;" />
      <TextField fx:id="btnPuerto" layoutX="35.0" layoutY="237.0" promptText="PUERTO" style="-fx-background-color: black; -fx-text-fill: white;" />
      <Label layoutX="393.0" layoutY="110.0" style="-fx-background-color: black;" text="USUARIO" textFill="WHITE" />
      <Label layoutX="380.0" layoutY="172.0" style="-fx-background-color: black;" text="CONTRASEÑA" textFill="WHITE" />
      <PasswordField fx:id="btnUsuario" layoutX="344.0" layoutY="131.0" style="-fx-text-fill: white; -fx-background-color: black;" />
      <PasswordField fx:id="btnContraseña" layoutX="344.0" layoutY="197.0" style="-fx-text-fill: white; -fx-background-color: black;" />
   </children>
</Pane>
