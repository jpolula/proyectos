      <RadioButton fx:id="rdbtDificultad4" layoutX="154.0" layoutY="75.0" mnemonicParsing="false" prefHeight="18.0" prefWidth="76.0" style="-fx-background-color: black;" text="Pesadilla" textFill="WHITE">
