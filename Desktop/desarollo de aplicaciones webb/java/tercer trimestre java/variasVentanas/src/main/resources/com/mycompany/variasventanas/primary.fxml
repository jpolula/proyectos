<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.Pane?>

<Pane prefHeight="403.0" prefWidth="506.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.variasventanas.PrimaryController">
   <children>
      <Button fx:id="abrir1" layoutX="55.0" layoutY="142.0" onMouseClicked="#abrir1" text="Abrir1">
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Label layoutX="190.0" layoutY="42.0" text="Soy la ventana principal" />
      <ColorPicker layoutX="184.0" layoutY="83.0" />
      <Button fx:id="abrir2" layoutX="55.0" layoutY="195.0" onMouseClicked="#abrir2" text="Abrir2">
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Label layoutX="133.0" layoutY="146.0" text="Abre una nueva ventana MANTENIENDO abierta la actual" />
      <Label layoutX="133.0" layoutY="199.0" text="Abre una nueva ventana CERRANDO la actual" />
      <Button fx:id="abrir3" layoutX="55.0" layoutY="245.0" onMouseClicked="#abrir3" text="Abrir3">
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Label layoutX="133.0" layoutY="249.0" text="Abre una nueva ventana en formato MODAL" />
      <Button fx:id="abrir4" layoutX="55.0" layoutY="297.0" onMouseClicked="#abrir4" text="Abrir4">
         <effect>
            <DropShadow />
         </effect>
      </Button>
      <Label layoutX="133.0" layoutY="301.0" text="Abre una nueva ventana pasando una información:" />
      <TextField fx:id="txtEnviado" layoutX="190.0" layoutY="333.0" promptText="Valor enviado..." />
      <TextField fx:id="txtDevuelto" editable="false" layoutX="190.0" layoutY="364.0" promptText="Valor devuelto..." />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</Pane>
