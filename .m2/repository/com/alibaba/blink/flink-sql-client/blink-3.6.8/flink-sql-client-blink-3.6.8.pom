    <dependency>
      <groupId>com.alibaba.blink</groupId>
      <artifactId>flink-connector-kafka-0.11_2.11</artifactId>
      <version>blink-3.6.8</version>
      <scope>test</scope>
      <exclusions>
        <exclusion>
          <artifactId>scala-parser-combinators_2.11</artifactId>
